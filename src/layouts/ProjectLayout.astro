---
import type { Project } from '../data/projects';
import BaseLayout from './BaseLayout.astro';
import { withBase, isExternal } from '../utils/paths';
import { getImageDims } from '../utils/imageDims';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const image = project.heroAsset.src;
const title = project.seo.title ?? project.title;
const description = project.seo.description ?? project.summary;
const siteUrl = Astro.site ?? new URL('https://reesehollister.com');
const projectUrl = new URL(`/projects/${project.slug}/`, siteUrl).toString();
const visibleLinks = project.links.filter((link) => link.available !== false);
const deck = project.deck;
const videos = project.videos ?? [];
const ytVideos = project.ytVideos ?? [];
const materialLinks = [
  ...(deck ? [{ label: 'Deck', href: '#deck' }] : []),
  ...(ytVideos.length > 0 ? [{ label: 'Watch', href: '#watch' }] : []),
  ...visibleLinks.map((link) => ({
    label: link.shortLabel ?? link.label,
    href: link.href
  }))
];
---

<BaseLayout title={title} description={description} image={image}>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'CreativeWork',
    name: title,
    description: description,
    url: projectUrl,
    image: new URL(withBase(image), siteUrl).toString(),
    author: {
      '@type': 'Person',
      name: 'Reese W. Hollister',
      url: siteUrl.toString()
    },
    keywords: project.skills?.join(', ') ?? project.categories.join(', '),
    genre: project.categories.join(', ')
  })} slot="head" />
  <article class="project-page">
    <section class={`project-hero site-shell${project.heroVideo ? ' has-video-backdrop' : ''}`}>
      {project.heroVideo && (
        <>
          <video
            class="video-backdrop"
            autoplay
            muted
            loop
            playsinline
            preload="none"
            src={withBase(project.heroVideo)}
          ></video>
          <div class="video-backdrop-scrim"></div>
        </>
      )}
      <p class="section-kicker">Project</p>
      <h1>{project.title}</h1>
      <p class="project-hero__summary">{project.summary}</p>
      <figure class="project-hero__media">
        <img
          src={withBase(project.heroAsset.src)}
          alt={project.heroAsset.alt}
          width={getImageDims(project.heroAsset.src)?.width}
          height={getImageDims(project.heroAsset.src)?.height}
        />
        {project.heroAsset.caption && <figcaption>{project.heroAsset.caption}</figcaption>}
      </figure>
      <ul class="project-hero__meta">
        <li>
          <span class="project-meta-label">Role</span>
          <p>{project.role}</p>
        </li>
        <li>
          <span class="project-meta-label">Areas</span>
          <p>{project.categories.join(' / ')}</p>
        </li>
        <li>
          <span class="project-meta-label">Skills</span>
          <p>{project.skills.join(', ')}</p>
        </li>
      </ul>
      {materialLinks.length > 0 && (
        <nav class="materials-rail" aria-label="Open project materials">
          <span class="materials-rail__label">Open materials</span>
          <ul>
          {materialLinks.map((link) => (
            <li>
              <a
                class="materials-rail__link"
                href={withBase(link.href)}
                target={isExternal(link.href) ? '_blank' : undefined}
                rel={isExternal(link.href) ? 'noreferrer' : undefined}
              >
                {link.label}
              </a>
            </li>
          ))}
          </ul>
        </nav>
      )}
    </section>
    {deck && (
      <section class="project-deck site-shell" id="deck">
        <div class="project-deck__head">
          <p class="section-kicker">The deck</p>
          <h2>{deck.title}</h2>
          <a class="deck-download" href={withBase(deck.pdf)} target="_blank" rel="noreferrer">Download the full deck (PDF) →</a>
        </div>
        <div class="deck-strip" tabindex="0" aria-label={`${deck.title} — slide deck, scroll horizontally to advance`}>
          {Array.from({ length: deck.slideCount }, (_, i) => {
            const n = String(i + 1).padStart(2, '0');
            return (
              <figure class="deck-slide">
                <img
                  src={withBase(`${deck.slidePrefix}-${n}.${deck.slideExt ?? 'jpg'}`)}
                  alt={`${deck.title} — slide ${i + 1} of ${deck.slideCount}`}
                  loading="lazy"
                />
              </figure>
            );
          })}
        </div>
        <p class="deck-hint">Scroll or swipe through all {deck.slideCount} slides — or open the full PDF above.</p>
      </section>
    )}
    {videos.length > 0 && (
      <section class="project-videos site-shell" id="video">
        <p class="section-kicker">In motion</p>
        <div class={`project-videos__grid project-videos__grid--${videos.length === 1 ? 'solo' : 'pair'}`}>
          {videos.map((video) => {
            const dims = getImageDims(video.poster);
            return (
              <figure class={`project-video project-video--${video.mode === 'play' ? 'play' : 'loop'}`}>
                <div class="project-video__frame">
                  {video.mode === 'play' ? (
                    <>
                      <video
                        src={withBase(video.src)}
                        poster={withBase(video.poster)}
                        width={dims?.width}
                        height={dims?.height}
                        preload="none"
                        playsinline
                      ></video>
                      <button class="project-video__play" type="button" aria-label="Play video">
                        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                          <path d="M8 5.5v13a1 1 0 0 0 1.5.87l11-6.5a1 1 0 0 0 0-1.74l-11-6.5A1 1 0 0 0 8 5.5Z" />
                        </svg>
                      </button>
                    </>
                  ) : (
                    <>
                      <video
                        src={withBase(video.src)}
                        poster={withBase(video.poster)}
                        width={dims?.width}
                        height={dims?.height}
                        autoplay
                        muted
                        loop
                        playsinline
                        preload="metadata"
                      ></video>
                      <span class="project-video__badge" aria-hidden="true">Loop</span>
                    </>
                  )}
                </div>
                <figcaption>{video.caption}</figcaption>
              </figure>
            );
          })}
        </div>
      </section>
    )}
    {ytVideos.length > 0 && (
      <section class="project-yt-videos site-shell" id="watch">
        <p class="section-kicker">Watch</p>
        <div class={`yt-videos-grid yt-videos-grid--${ytVideos[0].aspect === 'portrait' ? 'shorts' : 'landscape'}`}>
          {ytVideos.map((vid) => (
            <a
              class={`yt-video-card yt-video-card--${vid.aspect ?? 'landscape'}`}
              href={`https://www.youtube.com/watch?v=${vid.ytId}`}
              target="_blank"
              rel="noreferrer"
              aria-label={`Watch: ${vid.title}`}
            >
              <div class="yt-video-card__thumb">
                <img
                  src={`https://img.youtube.com/vi/${vid.ytId}/hqdefault.jpg`}
                  alt={vid.title}
                  loading="lazy"
                />
                <span class="yt-video-card__play" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="currentColor" width="36" height="36">
                    <path d="M8 5.5v13a1 1 0 0 0 1.5.87l11-6.5a1 1 0 0 0 0-1.74l-11-6.5A1 1 0 0 0 8 5.5Z"/>
                  </svg>
                </span>
              </div>
              {vid.caption && <p class="yt-video-card__caption">{vid.caption}</p>}
            </a>
          ))}
        </div>
      </section>
    )}
    <section class="project-body site-shell prose-shell">
      <slot />
    </section>
  </article>
</BaseLayout>

<script>
  // Click-to-play for play-mode project videos: show a styled poster + play
  // button, then reveal native controls once the user starts the clip. No
  // browser chrome before play; keeps the section feeling intentional.
  function setupProjectVideos() {
    document.querySelectorAll('.project-video--play').forEach((figure) => {
      if (!(figure instanceof HTMLElement)) return;
      const video = figure.querySelector('video');
      const button = figure.querySelector('.project-video__play');
      if (!video || !button || figure.dataset.wired === 'true') return;
      figure.dataset.wired = 'true';
      const start = () => {
        figure.classList.add('is-playing');
        video.setAttribute('controls', '');
        video.play().catch(() => {});
      };
      button.addEventListener('click', start);
      video.addEventListener('click', () => {
        if (!figure.classList.contains('is-playing')) start();
      });
    });
  }
  document.addEventListener('astro:page-load', setupProjectVideos);
</script>
