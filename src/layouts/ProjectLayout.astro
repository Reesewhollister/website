---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import { withBase, isExternal } from '../utils/paths';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const image = project.data.heroAsset.src;
const title = project.data.seo.title ?? project.data.title;
const description = project.data.seo.description ?? project.data.summary;
---

<BaseLayout title={title} description={description} image={image}>
  <article class="project-page">
    <section class="project-hero site-shell">
      <p class="section-kicker">Project</p>
      <h1>{project.data.title}</h1>
      <p class="project-hero__summary">{project.data.summary}</p>
      <figure class="project-hero__media">
        <img src={withBase(project.data.heroAsset.src)} alt={project.data.heroAsset.alt} />
        {project.data.heroAsset.caption && <figcaption>{project.data.heroAsset.caption}</figcaption>}
      </figure>
      <ul class="project-hero__meta">
        <li>
          <span class="project-meta-label">Role</span>
          <p>{project.data.role}</p>
        </li>
        <li>
          <span class="project-meta-label">Areas</span>
          <p>{project.data.categories.join(' / ')}</p>
        </li>
        <li>
          <span class="project-meta-label">Skills</span>
          <p>{project.data.skills.join(', ')}</p>
        </li>
      </ul>
      {project.data.links.length > 0 && (
        <ul class="action-list">
          {project.data.links.map((link) => (
            <li>
              {link.available ? (
                <a
                  class="action-link"
                  href={withBase(link.href)}
                  target={isExternal(link.href) ? '_blank' : undefined}
                  rel={isExternal(link.href) ? 'noreferrer' : undefined}
                >
                  {link.label}
                </a>
              ) : (
                <span class="action-link is-disabled">{link.label}</span>
              )}
              {link.note && <span class="action-note">{link.note}</span>}
            </li>
          ))}
        </ul>
      )}
    </section>
    <section class="project-body site-shell prose-shell">
      <slot />
    </section>
  </article>
</BaseLayout>
