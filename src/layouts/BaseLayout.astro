---
import { ClientRouter } from 'astro:transitions';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import '../styles/global.css';
import { siteMeta } from '../data/site';
import { withBase } from '../utils/paths';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = siteMeta.title,
  description = siteMeta.description,
  image = '/assets/fieldwork/og/og-home.jpg'
} = Astro.props;

const pageTitle = title === siteMeta.title ? title : `${title} | ${siteMeta.title}`;
const siteUrl = Astro.site ?? new URL('https://reesehollister.com');
const canonical = new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = new URL(withBase(image), siteUrl).toString();
const faviconHref = withBase('/assets/ui/favicon.svg');
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-V4RR8JGB9W"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-V4RR8JGB9W');
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Reese W. Hollister" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={faviconHref} />
    <link rel="apple-touch-icon" sizes="180x180" href={withBase('/assets/ui/apple-touch-icon.png')} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: 'Reese W. Hollister',
      url: siteUrl.toString(),
      image: new URL(withBase('/assets/fieldwork/og/og-home.jpg'), siteUrl).toString(),
      jobTitle: 'Historian, Educator, and Writing Consultant',
      description: 'Historian of North Africa and postcolonial institutions, Fulbright Scholar, CRLA Level III writing consultant, and educational media maker based in Bucks County, PA.',
      alumniOf: {
        '@type': 'CollegeOrUniversity',
        name: 'North Carolina State University'
      },
      affiliation: [
        { '@type': 'CollegeOrUniversity', name: 'North Carolina State University' },
        { '@type': 'CollegeOrUniversity', name: 'Al Akhawayn University in Ifrane' }
      ],
      award: [
        'Fulbright Scholar – Morocco 2023–24',
        'VenturePack Winner – NC State 2026'
      ],
      hasCredential: [
        { '@type': 'EducationalOccupationalCredential', name: 'CRLA Level III Writing Consultant' },
        { '@type': 'EducationalOccupationalCredential', name: 'Fulbright Scholar, U.S. Department of State' },
        { '@type': 'EducationalOccupationalCredential', name: 'Master of International Studies, NC State University' }
      ],
      knowsLanguage: ['English', 'Arabic', 'French'],
      knowsAbout: ['North African history', 'Morocco', 'Western Sahara', 'Postcolonial institutions', 'Arabic language education', 'Academic writing', 'Fulbright Program', 'Digital history', 'Public history'],
      sameAs: [
        'https://ncsu.academia.edu/ReeseHollister',
        'https://www.youtube.com/@HistoricalMethodMan/featured',
        'https://github.com/Reesewhollister',
        'https://www.linkedin.com/in/reese-h-13b09519a/'
      ]
    })} />
    <slot name="head" />
    <ClientRouter />
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <SiteHeader />
    <main id="content">
      <slot />
    </main>
    <SiteFooter />
    <script>
      // Scroll-reveal for sections. Safe by design: content is only hidden
      // once JS has run and the user has not requested reduced motion.
      function setupReveals() {
        const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const sections = Array.from(document.querySelectorAll('main > section'));
        if (prefersReduced || !('IntersectionObserver' in window)) {
          sections.forEach((s) => s.classList.add('is-visible'));
          return;
        }
        document.documentElement.classList.add('reveal-ready');
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            });
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.06 }
        );
        sections.forEach((section) => {
          // Never hide the cinematic hero (it has its own entrance animation).
          if (section.classList.contains('cinematic-hero')) {
            section.classList.add('is-visible');
            return;
          }
          section.classList.add('reveal');
          io.observe(section);
        });
      }
      document.addEventListener('astro:page-load', setupReveals);
    </script>
  </body>
</html>
