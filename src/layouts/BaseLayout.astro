---
import { ClientRouter } from 'astro:transitions';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import '../styles/global.css';
import { siteMeta } from '../data/site';
import { withBase } from '../utils/paths';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = siteMeta.title,
  description = siteMeta.description,
  image = '/assets/ui/chefchaouen-01.jpg'
} = Astro.props;

const pageTitle = title === siteMeta.title ? title : `${title} | ${siteMeta.title}`;
const siteUrl = Astro.site ?? new URL('https://reesehollister.com');
const canonical = new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = new URL(withBase(image), siteUrl).toString();
const faviconHref = withBase('/assets/ui/favicon.svg');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={faviconHref} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <ClientRouter />
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <SiteHeader />
    <main id="content">
      <slot />
    </main>
    <SiteFooter />
    <script>
      // Scroll-reveal for sections. Safe by design: content is only hidden
      // once JS has run and the user has not requested reduced motion.
      function setupReveals() {
        const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const sections = Array.from(document.querySelectorAll('main > section'));
        if (prefersReduced || !('IntersectionObserver' in window)) {
          sections.forEach((s) => s.classList.add('is-visible'));
          return;
        }
        document.documentElement.classList.add('reveal-ready');
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            });
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.06 }
        );
        sections.forEach((section) => {
          // Never hide the cinematic hero (it has its own entrance animation).
          if (section.classList.contains('cinematic-hero')) {
            section.classList.add('is-visible');
            return;
          }
          section.classList.add('reveal');
          io.observe(section);
        });
      }
      document.addEventListener('astro:page-load', setupReveals);
    </script>
  </body>
</html>
