---
import type { CollectionEntry } from 'astro:content';
import { withBase } from '../utils/paths';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const href = `/projects/${project.slug}`;
const heroSrc = withBase(project.data.heroAsset.src);
---

<article class="project-card" data-categories={project.data.categories.join('|')}>
  <a class="project-card__media" href={withBase(href)}>
    <img src={heroSrc} alt={project.data.heroAsset.alt} loading="lazy" />
  </a>
  <div class="project-card__body">
    <h3>
      <a href={withBase(href)}>{project.data.title}</a>
    </h3>
    <p class="project-card__meta">{project.data.categories.join(' / ')}</p>
    <p>{project.data.summary}</p>
    <p class="project-card__role">Role: {project.data.role}</p>
  </div>
</article>
