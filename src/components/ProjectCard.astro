---
import type { Project } from '../data/projects';
import { withBase } from '../utils/paths';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const href = `/projects/${project.slug}`;
const heroSrc = withBase(project.heroAsset.src);
---

<article class="project-card" data-categories={project.categories.join('|')}>
  <a class="project-card__media" href={withBase(href)}>
    <img src={heroSrc} alt={project.heroAsset.alt} loading="lazy" />
  </a>
  <div class="project-card__body">
    <h3>
      <a href={withBase(href)}>{project.title}</a>
    </h3>
    <p class="project-card__meta">{project.categories.join(' / ')}</p>
    <p>{project.summary}</p>
    <p class="project-card__role">Role: {project.role}</p>
  </div>
</article>
