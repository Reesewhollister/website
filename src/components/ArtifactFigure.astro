---
import { withBase } from '../utils/paths';
import { getImageDims } from '../utils/imageDims';

interface Props {
  src: string;
  alt: string;
  caption?: string;
  eyebrow?: string;
}

const { src, alt, caption, eyebrow } = Astro.props;
const dims = getImageDims(src);
---

<figure class="artifact-figure">
  <img src={withBase(src)} alt={alt} loading="lazy" width={dims?.width} height={dims?.height} />
  {(caption || eyebrow) && (
    <figcaption>
      {eyebrow && <span class="artifact-figure__eyebrow">{eyebrow}</span>}
      {caption && <span>{caption}</span>}
    </figcaption>
  )}
</figure>

