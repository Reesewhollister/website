---
interface NavLink {
  label: string;
  href: string;
}

interface Props {
  links: NavLink[];
}

const { links } = Astro.props;
if (links.length < 2) return;
---

<nav class="project-subnav" aria-label="Project sections">
  <ul class="project-subnav__list site-shell">
    {links.map((link) => (
      <li>
        <a
          class="project-subnav__link"
          href={link.href}
          data-subnav-href={link.href}
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>
</nav>

<script>
  (function () {
    const nav = document.querySelector('.project-subnav');
    if (!nav || !('IntersectionObserver' in window)) return;

    const links = Array.from(nav.querySelectorAll('[data-subnav-href]'));
    if (links.length === 0) return;

    const sectionIds = links
      .map((l) => (l as HTMLAnchorElement).getAttribute('data-subnav-href')?.replace('#', ''))
      .filter(Boolean);

    const sections = sectionIds
      .map((id) => document.getElementById(id!))
      .filter(Boolean) as HTMLElement[];

    if (sections.length === 0) return;

    let current = '';

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            current = '#' + entry.target.id;
          }
        }
        links.forEach((link) => {
          const href = (link as HTMLAnchorElement).getAttribute('data-subnav-href');
          link.classList.toggle('is-active', href === current);
        });
      },
      { rootMargin: '-20% 0px -60% 0px', threshold: 0 }
    );

    sections.forEach((s) => observer.observe(s));
  })();
</script>
