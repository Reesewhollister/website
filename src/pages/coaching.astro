---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { coachingServices, coachingBookingUrl } from '../data/site';
import { withBase } from '../utils/paths';
---

<BaseLayout
  title="Writing Coaching in Bucks County, PA"
  description="One-on-one writing coaching in Bucks County, PA and online — college essays, research papers, and personal statements with Reese Hollister, a CRLA Level III certified writing consultant serving Newtown, Yardley, Richboro, and Washington Crossing."
  image="/assets/fieldwork/og/og-coaching.jpg"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Service',
    serviceType: 'Writing coaching and academic tutoring',
    name: 'Writing Coaching with Reese Hollister',
    description:
      'One-on-one writing coaching for college essays, research papers, personal statements, and academic writing, from high school through graduate school. In person in Bucks County, Pennsylvania, or online.',
    url: 'https://reesehollister.com/coaching/',
    provider: {
      '@type': 'Person',
      name: 'Reese W. Hollister',
      url: 'https://reesehollister.com/',
      hasCredential: 'CRLA Level III certified writing consultant'
    },
    areaServed: [
      { '@type': 'Place', name: 'Bucks County, PA' },
      { '@type': 'Place', name: 'Newtown, PA' },
      { '@type': 'Place', name: 'Yardley, PA' },
      { '@type': 'Place', name: 'Richboro, PA' },
      { '@type': 'Place', name: 'Washington Crossing, PA' },
      { '@type': 'Place', name: 'Online' }
    ],
    audience: {
      '@type': 'EducationalAudience',
      educationalRole: 'student'
    }
  })} />
  <section class="page-hero site-shell">
    <p class="section-kicker">Writing Coaching</p>
    <h1>Writing Coaching</h1>
    <p class="page-lead">
      One-on-one writing support for college essays, research papers, personal statements, and academic writing.
    </p>
    <p>
      Level III CRLA-certified, based in Bucks County, and available online.
    </p>
    <ul class="home-hero__links">
      <li><a href={coachingBookingUrl} target="_blank" rel="noreferrer">Book a consultation</a></li>
      <li><a href={withBase('/teaching')}>Full teaching background</a></li>
    </ul>
  </section>

  <section class="site-shell">
    <SectionHeading
      eyebrow="Coaching"
      title="What I help with"
      intro="Focused help for the stage your draft is actually in."
    />
    <div class="pillars-grid">
      {coachingServices.map((service) => (
        <article class="pillar-card">
          <h3>{service.title}</h3>
          <p>{service.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="site-shell">
    <SectionHeading
      eyebrow="Background"
      title="Credentials"
      intro="Practical writing support backed by teaching and research experience."
    />
    <div class="resume-highlight-grid">
      <article class="resume-card">
        <h3>Certified consultant</h3>
        <ul>
          <li>Level III CRLA-certified writing consultant.</li>
          <li>Years of one-on-one consultation across disciplines and assignment types.</li>
        </ul>
      </article>
      <article class="resume-card">
        <h3>Trained researcher and writer</h3>
        <ul>
          <li>Published in peer-reviewed history journals.</li>
          <li>Graduate-level research and argumentation experience in history and political science.</li>
        </ul>
      </article>
      <article class="resume-card">
        <h3>Teaching background</h3>
        <ul>
          <li>Graduate Teaching Assistant in political science and international studies.</li>
          <li>History teacher and university-access writing instructor in Rabat, Morocco.</li>
        </ul>
      </article>
    </div>
  </section>

  <section class="site-shell">
    <SectionHeading
      eyebrow="Process"
      title="How sessions work"
      intro="Every session follows the same three phases — the details depend on what the draft needs."
    />
    <div class="session-phases">
      <details class="session-phase">
        <summary class="session-phase__summary">
          <span class="session-phase__label">Before</span>
          <span class="session-phase__desc">Send the draft, prompt, and context</span>
        </summary>
        <div class="session-phase__detail">
          <p>Share the assignment prompt or thesis requirement, the draft you have (or a description of what you're working on), and the deadline. A sentence about where you feel stuck is more useful than a long explanation. I read everything before the session so we can spend the time working, not orienting.</p>
        </div>
      </details>
      <details class="session-phase">
        <summary class="session-phase__summary">
          <span class="session-phase__label">During</span>
          <span class="session-phase__desc">Targeted conversation on the draft</span>
        </summary>
        <div class="session-phase__detail">
          <p>Sessions are 60–90 minutes and move through the draft with a specific question: What is the argument doing here? Where is the evidence thin? Does the reader know what to do with this paragraph? I mark up the draft as we talk and explain the edits so you understand why, not just what changed.</p>
        </div>
      </details>
      <details class="session-phase">
        <summary class="session-phase__summary">
          <span class="session-phase__label">After</span>
          <span class="session-phase__desc">Annotated draft + next steps</span>
        </summary>
        <div class="session-phase__detail">
          <p>You leave with a marked draft and a short list of specific revisions ranked by impact. If there's a follow-up session, I read the revision before we meet so you're not re-explaining the project. For ongoing clients, we build a shared sense of your writing patterns over time.</p>
        </div>
      </details>
    </div>
  </section>

  <section class="site-shell">
    <SectionHeading
      eyebrow="What do you need?"
      title="Find the right kind of help"
      intro="Different stages need different kinds of work. Pick what fits."
    />
    <div class="writing-chooser">
      <details class="writing-chooser__item">
        <summary>I have a rough draft and don't know if the argument works</summary>
        <div class="writing-chooser__detail">
          <p>This is a structural read. I'll identify where the claim is, whether the evidence supports it, where the reader will get lost, and what the revision priority should be. Good for any stage from outline through second draft.</p>
          <a href={coachingBookingUrl} target="_blank" rel="noreferrer">Book a structure session →</a>
        </div>
      </details>
      <details class="writing-chooser__item">
        <summary>I'm writing a college essay or personal statement</summary>
        <div class="writing-chooser__detail">
          <p>The challenge with personal statements is that students try to say everything and end up saying nothing. We'll narrow the focus to one or two specific moments that carry the whole essay, and make the voice feel like you wrote it — not like a template.</p>
          <a href={coachingBookingUrl} target="_blank" rel="noreferrer">Book a personal statement session →</a>
        </div>
      </details>
      <details class="writing-chooser__item">
        <summary>I need help with citations, formatting, or academic style</summary>
        <div class="writing-chooser__detail">
          <p>Chicago, MLA, APA — I work across citation styles and can explain the logic behind the rules rather than just correcting the format. Usually combined with a substantive session rather than done alone.</p>
          <a href={coachingBookingUrl} target="_blank" rel="noreferrer">Book a session →</a>
        </div>
      </details>
      <details class="writing-chooser__item">
        <summary>I'm applying to graduate school</summary>
        <div class="writing-chooser__detail">
          <p>Statement of purpose, writing sample selection and framing, diversity statement — the application package tells a story, and the pieces need to reinforce each other. I've been through the PhD application cycle and know what strong SOPs do differently.</p>
          <a href={coachingBookingUrl} target="_blank" rel="noreferrer">Book a grad school application session →</a>
        </div>
      </details>
    </div>
  </section>

  <section class="site-shell">
    <SectionHeading
      eyebrow="Contact"
      title="Book a session"
      intro="Choose a time online or email a short note."
    />
    <div class="contact-grid contact-grid--linear">
      <article class="contact-card">
        <h3>Book online</h3>
        <p>
          Pick a time and tell me what the draft needs to do.
        </p>
        <ul class="action-list">
          <li>
            <a class="action-link" href={coachingBookingUrl} target="_blank" rel="noreferrer">Book a consultation →</a>
            <span class="action-note">Online booking and current availability.</span>
          </li>
        </ul>
      </article>
      <article class="contact-card">
        <h3>Email about a session</h3>
        <p>
          Send the assignment, timeline, and whether you want a one-time session or ongoing support.
        </p>
        <ul class="action-list">
          <li>
            <a class="action-link" href="mailto:reesewhollister@gmail.com">reesewhollister@gmail.com</a>
            <span class="action-note">I respond within one to two business days.</span>
          </li>
        </ul>
      </article>
    </div>
  </section>
</BaseLayout>
