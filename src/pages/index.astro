---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { homeIntro, homePillars, proofItems, siteMeta } from '../data/site';
import { withBase, isExternal } from '../utils/paths';

const featuredProjects = (await getCollection('projects'))
  .filter((project) => project.data.featured)
  .sort((left, right) => left.data.sortOrder - right.data.sortOrder);
---

<BaseLayout title={siteMeta.title} description={siteMeta.description}>
  <section class="home-hero site-shell">
    <div class="home-hero__layout">
      <div class="home-hero__copy">
        <p class="section-kicker">Welcome</p>
        <h1>Reese Hollister</h1>
        <p class="home-hero__lead">{siteMeta.position}</p>
        <p class="home-hero__intro">Marhaba! Bienvenue! Welcome!</p>
        <p class="home-hero__intro">{homeIntro}</p>
        <p class="home-hero__intro">
          I lived in Morocco on a Fulbright research grant from August 2023 through June 2024, conducting field research, teaching
          history, and studying Arabic — work that now shapes everything I do.
        </p>
        <ul class="home-hero__links">
          <li><a href={withBase('/about')}>About</a></li>
          <li><a href={withBase('/projects')}>Projects</a></li>
          <li><a href="https://sites.google.com/ncsu.edu/reese/welcome?pli=1" target="_blank" rel="noreferrer">Original site</a></li>
        </ul>
      </div>
      <div class="home-hero__media">
        <figure class="home-intro-figure home-intro-figure--primary">
          <img
            src={withBase('/assets/ui/2026-03-31__reese-portfolio__asset__v02__google-site-welcome-photo.jpg')}
            alt="Reese in Morocco in a public photo previously used on his original site."
          />
          <figcaption>Public photo from Reese&apos;s original NCSU site.</figcaption>
        </figure>
        <div class="home-hero__media-stack">
          <figure class="home-intro-figure home-intro-figure--portrait">
            <img
              src={withBase('/assets/ui/2026-03-31__reese-portfolio__asset__v01__reese-public-profile.jpg')}
              alt="Public profile portrait of Reese Hollister."
            />
            <figcaption>Public profile portrait.</figcaption>
          </figure>
          <figure class="home-intro-figure home-intro-figure--publication">
            <img
              src={withBase('/assets/ui/2026-03-31__reese-portfolio__asset__v01__history-matters-publication-thumb.jpg')}
              alt="History Matters publication cover previously used in Reese Hollister's public materials."
            />
            <figcaption>History Matters, 2023.</figcaption>
          </figure>
        </div>
      </div>
    </div>
  </section>

  <section class="site-shell">
    <SectionHeading
      eyebrow="What I Do"
      title="Research, teaching, and building"
      intro="These are the main threads that run through the site."
    />
    <div class="pillars-grid">
      {homePillars.map((pillar) => (
        <article class="pillar-card">
          <h3>{pillar.title}</h3>
          <p>{pillar.summary}</p>
          <ul>
            {pillar.details.map((detail) => <li>{detail}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="site-shell">
    <SectionHeading
      eyebrow="Selected Work"
      title="Projects and longer pieces of work"
      intro="A few of the larger projects that bring these interests together."
    />
    <div class="project-grid">
      {featuredProjects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="site-shell">
    <SectionHeading
      eyebrow="Elsewhere"
      title="Public work and older pages"
      intro="Some of this work also lives on older public pages and platforms."
    />
    <div class="proof-grid">
      {proofItems.map((item) => (
        <article class="proof-card">
          <p class="section-kicker">{item.type}</p>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
          <div class="action-list">
            <a
              class="resource-link"
              href={withBase(item.href)}
              target={isExternal(item.href) ? '_blank' : undefined}
              rel={isExternal(item.href) ? 'noreferrer' : undefined}
            >
              {item.cta}
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
