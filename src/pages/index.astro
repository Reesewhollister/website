---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { heroThesis, whatIDo, proofStrip, serviceCards, coachingCta, contactCta, siteMeta } from '../data/site';
import { featuredProjects, getProjectBySlug } from '../data/projects';
import { withBase, isExternal } from '../utils/paths';

const spotlight = getProjectBySlug('from-colonies-to-carriers');
const otherProjects = featuredProjects.filter((project) => project.slug !== spotlight?.slug);
---

<BaseLayout title={siteMeta.title} description={siteMeta.description}>
  <section class="cinematic-hero">
    <div class="cinematic-hero__media">
      <img
        src={withBase('/assets/ui/chefchaouen-01.jpg')}
        alt="Chefchaouen, the blue-washed city of northern Morocco, where Reese conducted Fulbright fieldwork."
        fetchpriority="high"
      />
    </div>
    <div class="cinematic-hero__inner site-shell">
      <p class="cinematic-hero__kicker">Reese W. Hollister · Historian of North Africa</p>
      <h1 class="cinematic-hero__title">{heroThesis}</h1>
      <p class="cinematic-hero__tagline">{siteMeta.position}</p>
      <p class="cinematic-hero__lead">
        Research, writing, teaching, and media — one through-line, from Moroccan mountain towns to African airlines.
      </p>
      <ul class="cinematic-hero__actions">
        <li><a href={withBase('/research')}>View Research</a></li>
        <li><a href={withBase('/coaching')}>Book a Consultation</a></li>
        <li><a href="https://www.youtube.com/@HistoricalMethodMan/featured" target="_blank" rel="noreferrer">Watch the Channel</a></li>
        <li><a href={withBase('/resume')}>Download CV</a></li>
      </ul>
    </div>
    <span class="cinematic-hero__credit">Chefchaouen, Morocco</span>
  </section>

  <section class="site-shell proof-strip-section">
    <ul class="proof-strip">
      {proofStrip.map((item) => (
        <li class="proof-strip__item">
          <span class="proof-strip__label">{item.label}</span>
          <span class="proof-strip__detail">{item.detail}</span>
        </li>
      ))}
    </ul>
  </section>

  <section class="site-shell">
    <SectionHeading
      eyebrow="What I do"
      title="From complex material to clear communication"
    />
    <div class="prose-shell">
      {whatIDo.map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </section>

  <section class="site-shell">
    <SectionHeading
      eyebrow="Work with me"
      title="Three ways I help"
    />
    <div class="pillars-grid">
      {serviceCards.map((card) => (
        <article class="pillar-card service-card">
          <h3>{card.title}</h3>
          <p>{card.summary}</p>
          <a
            class="service-card__cta"
            href={withBase(card.href)}
            target={isExternal(card.href) ? '_blank' : undefined}
            rel={isExternal(card.href) ? 'noreferrer' : undefined}
          >
            {card.cta} →
          </a>
        </article>
      ))}
    </div>
  </section>

  {spotlight && (
    <section class="site-shell">
      <SectionHeading
        eyebrow="Featured project"
        title="From Colonies to Carriers"
      />
      <article class="featured-project">
        <a class="featured-project__media" href={withBase(`/projects/${spotlight.slug}`)}>
          <img src={withBase(spotlight.heroAsset.src)} alt={spotlight.heroAsset.alt} loading="lazy" />
        </a>
        <div class="featured-project__body">
          <p class="featured-project__meta">{spotlight.categories.join(' / ')}</p>
          <p>{spotlight.summary}</p>
          <p class="featured-project__note">
            A reconstructed dataset of early postcolonial African civil aviation, built from fragmentary archival
            records — with a case study on Royal Air Maroc.
          </p>
          <a class="featured-project__cta" href={withBase(`/projects/${spotlight.slug}`)}>
            Explore the project →
          </a>
        </div>
      </article>
    </section>
  )}

  <section class="site-shell">
    <article class="home-cta home-cta--coaching">
      <p class="section-kicker">{coachingCta.eyebrow}</p>
      <h2>{coachingCta.title}</h2>
      <p>{coachingCta.body}</p>
      <a class="home-cta__button" href={withBase(coachingCta.href)}>{coachingCta.cta} →</a>
    </article>
  </section>

  <section class="site-shell">
    <SectionHeading
      eyebrow="Selected work"
      title="Projects and longer pieces of work"
      intro="A few of the larger projects that bring these interests together."
    />
    <div class="project-grid">
      {otherProjects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="site-shell">
    <article class="home-cta home-cta--contact">
      <p class="section-kicker">{contactCta.eyebrow}</p>
      <h2>{contactCta.title}</h2>
      <p>{contactCta.body}</p>
      <a class="home-cta__button" href={withBase(contactCta.href)}>{contactCta.cta} →</a>
    </article>
  </section>
</BaseLayout>
