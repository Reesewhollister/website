---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { aboutTimeline } from '../data/site';
import { withBase } from '../utils/paths';
---

<BaseLayout
  title="About"
  description="About Reese Hollister: a scholar-builder working across historical research, international studies, pedagogy, and learning design."
  image="/assets/fieldwork/og/og-about.jpg"
>
  <section class="page-hero site-shell">
    <div class="about-hero__layout">
      <div class="about-hero__copy">
        <p class="section-kicker">About</p>
        <h1>About Reese Hollister</h1>
        <p class="page-lead">
          Reese Hollister is a historian and educator focused on North Africa, postcolonial institutions, and writing support.
        </p>
        <p>
          This site is organized around work samples: decks, datasets, maps, teaching, and public writing.
        </p>
      </div>
      <div class="about-hero__media">
        <figure class="about-inline-figure">
          <img
            class="about-portrait"
            src={withBase('/assets/fieldwork/cards/reese-aui-portrait-4x5.webp')}
            alt="Reese Hollister outside Al Akhawayn University in Ifrane, Morocco."
          />
          <figcaption class="about-portrait__caption">Al Akhawayn University, Ifrane, Morocco — Fulbright research base, 2023–24.</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <section class="site-shell">
    <SectionHeading
      eyebrow="Background"
      title="Three context points"
      intro="A short frame for the project work."
    />
    <ol class="timeline-list">
      {aboutTimeline.map((item) => (
        <li>
          <span class="timeline-label">{item.period}</span>
          <p>{item.summary}</p>
        </li>
      ))}
    </ol>
  </section>

  <section class="site-shell about-fieldwork-section">
    <SectionHeading
      eyebrow="Fieldwork"
      title="Morocco, 2023–24"
      intro="Fieldwork images from the Fulbright year — North Africa as a research site, not just a destination."
    />
    <div class="about-fieldwork-grid">
      <figure>
        <img
          src={withBase('/assets/fieldwork/heroes/chefchaouen-blue-plaza-hero-16x9.webp')}
          alt="The blue medina of Chefchaouen, Morocco — narrow streets and blue-washed buildings."
          loading="lazy"
        />
        <figcaption>Chefchaouen — fieldwork site and visual language study.</figcaption>
      </figure>
      <figure>
        <img
          src={withBase('/assets/fieldwork/cards/mohammed-vi-library-aui-card-4x3.webp')}
          alt="Mohammed VI Library at Al Akhawayn University, Ifrane, Morocco — the archival research base."
          loading="lazy"
        />
        <figcaption>Mohammed VI Library, AUI — primary archival research site.</figcaption>
      </figure>
      <figure>
        <img
          src={withBase('/assets/fieldwork/heroes/merzouga-dunes-camels-hero-16x9.webp')}
          alt="The Sahara dunes near Merzouga, Morocco, with camels and desert landscape."
          loading="lazy"
        />
        <figcaption>Merzouga, Sahara — reading mobility and landscape in the research frame.</figcaption>
      </figure>
    </div>
  </section>
</BaseLayout>
