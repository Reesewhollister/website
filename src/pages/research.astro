---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ResearchProcess from '../components/ResearchProcess.astro';
import { publications, presentations } from '../data/site';
import { getProjectBySlug, type Project } from '../data/projects';
import { withBase } from '../utils/paths';

const researchProjects = [
  'from-colonies-to-carriers',
  'western-sahara-capstone',
  'tazmamart',
  'fulbright-morocco'
]
  .map(getProjectBySlug)
  .filter((project): project is Project => Boolean(project));
---

<BaseLayout
  title="Research"
  description="Historical and political research by Reese Hollister — North Africa, postcolonial African institutions, French institutional history, and digital history methodology."
  image="/assets/fieldwork/og/og-research.jpg"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://reesehollister.com' },
      { '@type': 'ListItem', position: 2, name: 'Research', item: 'https://reesehollister.com/research' }
    ]
  })} slot="head" />
  <section class="page-hero site-shell">
    <div class="research-hero-bg" aria-hidden="true">
      <svg
        class="research-route-line"
        viewBox="0 0 900 64"
        preserveAspectRatio="none"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          class="route-main"
          d="M-20,46 C60,52 140,18 240,34 C340,50 400,12 500,28 C600,44 660,10 760,24 C810,31 860,36 920,32"
          stroke="var(--accent-map)"
          stroke-width="1.4"
          pathLength="1000"
          stroke-dasharray="1000"
          stroke-dashoffset="1000"
        />
        <path
          class="route-branch"
          d="M240,34 C268,50 302,60 344,62"
          stroke="var(--accent-rust)"
          stroke-width="0.9"
          pathLength="300"
          stroke-dasharray="300"
          stroke-dashoffset="300"
        />
        <circle class="route-dot" cx="240" cy="34" r="3.2" fill="var(--accent-rust)" opacity="0"/>
        <circle class="route-dot" cx="500" cy="28" r="3.2" fill="var(--accent-rust)" opacity="0"/>
        <circle class="route-dot" cx="760" cy="24" r="3.2" fill="var(--accent-map)" opacity="0"/>
      </svg>
    </div>
    <div class="research-compass-deco" aria-hidden="true">
      <img src={withBase('/assets/ui/compass-rose.svg')} alt="" width="64" height="64" loading="eager" />
    </div>
    <p class="section-kicker">Research</p>
    <h1>Research</h1>
    <p class="page-lead">
      Research on North Africa, infrastructure, mobility, sovereignty, and postcolonial state-building, with Morocco and Western Sahara at the center.
    </p>
    <p>
      My work combines archival research, fieldwork, digital mapping, historical datasets, and public-facing interpretation to study how roads, airlines, images, and state institutions made political authority visible and durable.
    </p>
  </section>

  <section class="site-shell research-agenda-section has-video-backdrop" aria-labelledby="research-agenda-heading">
    <video
      class="video-backdrop"
      autoplay
      muted
      loop
      playsinline
      preload="none"
      src={withBase('/assets/research/morocco-field-bg.mp4')}
    ></video>
    <div class="video-backdrop-scrim"></div>
    <img class="section-atlas-deco" src={withBase('/assets/ui/atlas-grid.svg')} alt="" aria-hidden="true" width="260" height="260" />
    <div class="research-agenda">
      <p id="research-agenda-heading" class="section-kicker">Research agenda</p>
      <p class="research-agenda__text">
        These projects ask how mobility systems, visual evidence, and state institutions turned claims into routines: roads that made territorial control durable, airlines that made sovereignty operational, and truth-commission archives that shaped the public limits of accountability.
      </p>
      <ul class="research-agenda__chips" aria-label="Research themes and methods">
        <li>Infrastructure &amp; sovereignty</li>
        <li>Archives &amp; visual evidence</li>
        <li>Digital mapping &amp; datasets</li>
        <li>Fieldwork &amp; language study</li>
      </ul>
    </div>
  </section>

  <section class="site-shell research-evidence-section">
    <SectionHeading
      eyebrow="Evidence base"
      title="Archives, fieldwork, and datasets"
      intro="The research is organized around inspectable materials: archival sites, field observation, reconstructed datasets, and visual sources."
    />
    <div class="research-evidence-grid">
      <figure class="research-evidence-card">
        <img
          src={withBase('/assets/fieldwork/heroes/mohammed-vi-library-aui-hero-16x9.webp')}
          alt="Mohammed VI Library at Al Akhawayn University in Ifrane, Morocco, an archival research base for Reese Hollister's Fulbright fieldwork."
          loading="lazy"
        />
        <figcaption>Archives: Mohammed VI Library, Al Akhawayn University, Ifrane.</figcaption>
      </figure>
      <figure class="research-evidence-card">
        <img
          src={withBase('/assets/projects/fulbright-morocco/jebel-shams-oman.jpg')}
          alt="Layered cliffs of Wadi Ghul at Jebel Shams, Oman, photographed during Arabic language study and comparative fieldwork."
          loading="lazy"
        />
        <figcaption>Field/language context: Jebel Shams and Wadi Ghul, Oman.</figcaption>
      </figure>
      <figure class="research-evidence-card">
        <img
          src={withBase('/assets/projects/from-colonies-to-carriers/2026-06-09__from-colonies-to-carriers__artifact__v01__atlas-panel.jpg')}
          alt="Atlas panel from the From Colonies to Carriers project showing African countries shaded by national airline count."
          loading="lazy"
        />
        <figcaption>Dataset work: postcolonial African airline atlas panel.</figcaption>
      </figure>
    </div>
  </section>

  <section class="site-shell research-clusters-section" aria-labelledby="research-clusters-heading">
    <p class="section-kicker">Research clusters</p>
    <h2 id="research-clusters-heading" class="section-title">Three lines of inquiry</h2>
    <div class="research-clusters">
      <article class="research-cluster">
        <h3 class="research-cluster__title">Mobility after empire</h3>
        <p class="research-cluster__body">
          How did newly independent African states use civil aviation, roads, and transport networks to build postcolonial sovereignty — and how did those infrastructure choices constrain and enable what came after? This cluster centers the From Colonies to Carriers dataset and the Western Sahara highway research.
        </p>
        <ul class="research-cluster__projects">
          <li><a href="/projects/from-colonies-to-carriers">From Colonies to Carriers</a></li>
          <li><a href="/projects/western-sahara-capstone">Western Sahara Highways</a></li>
        </ul>
      </article>
      <article class="research-cluster">
        <h3 class="research-cluster__title">Infrastructure and sovereignty</h3>
        <p class="research-cluster__body">
          Territory is not a given — it is made durable through infrastructure, administration, and repeated material presence. This cluster asks how roads, buildings, and state facilities turn contested claims into routine facts on the ground, with a focus on the Western Sahara conflict and Moroccan state-building after 1975.
        </p>
        <ul class="research-cluster__projects">
          <li><a href="/projects/western-sahara-capstone">Western Sahara Highways Capstone</a></li>
          <li><a href="/projects/fulbright-morocco">Fulbright Morocco</a></li>
        </ul>
      </article>
      <article class="research-cluster">
        <h3 class="research-cluster__title">Memory, justice, and state legitimacy</h3>
        <p class="research-cluster__body">
          Truth commissions, political prisons, and transitional justice archives — how do states manage the memory of political violence, and what does the management of that memory reveal about the limits of accountability? This cluster centers the Tazmamart research and the Equity and Reconciliation Commission.
        </p>
        <ul class="research-cluster__projects">
          <li><a href="/projects/tazmamart">Truth After Tazmamart</a></li>
        </ul>
      </article>
    </div>
  </section>

  <div class="site-shell geo-strip geo-strip--rust" aria-hidden="true">
    <img src={withBase('/assets/ui/ornament/zellige-strip.svg')} alt="" width="340" height="32" />
  </div>

  <ResearchProcess />

  <section class="site-shell research-mosaic-section" aria-label="Research project visuals">
    <div class="research-mosaic">
      {researchProjects.map((project) => (
        <a
          class="research-mosaic__item"
          data-accent={project.card?.accent ?? 'rust'}
          href={withBase(`/projects/${project.slug}`)}
        >
          <img src={withBase(project.heroAsset.src)} alt={project.heroAsset.alt} loading="lazy" />
          <span>{project.card?.title ?? project.title}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="site-shell">
    <SectionHeading
      eyebrow="Projects"
      title="Research projects"
      intro="The strongest research surfaces on the site."
    />
    <div class="project-grid project-grid--research">
      {researchProjects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="site-shell">
    <SectionHeading
      eyebrow="Publications"
      title="Published writing & research archive"
      intro="Earlier undergraduate research and public-facing history writing, kept as a compact archive behind the current project work."
    />
    <ul class="action-list action-list--stacked">
      {publications.map((pub) => (
        <li>
          <a class="resource-link" href={pub.href} target="_blank" rel="noreferrer">{pub.venue} — {pub.year}</a>
          <span class="action-note">{pub.title}</span>
        </li>
      ))}
      <li>
        <a class="resource-link" href="https://sites.google.com/ncsu.edu/reese/history-research?authuser=0" target="_blank" rel="noreferrer">
          Undergraduate research archive
        </a>
        <span class="action-note">Public NC State archive of earlier history research from Manhattan College, including published essays on colonial visual culture, museums, soft power, and anti-colonial politics.</span>
      </li>
      <li>
        <a class="resource-link" href="https://ncsu.academia.edu/ReeseHollister" target="_blank" rel="noreferrer">
          Full archive on Academia.edu
        </a>
        <span class="action-note">Research profile with all publications and presentations.</span>
      </li>
    </ul>
  </section>

  <section class="site-shell">
    <SectionHeading
      eyebrow="Presentations"
      title="Conference talks & presentations"
      intro="Selected talks delivered at academic conferences and graduate research events."
    />
    <ul class="action-list action-list--stacked">
      {presentations.map((talk) => (
        <li>
          {talk.internal ? (
            <a class="resource-link" href={withBase(talk.href)}>{talk.venue} — {talk.year}</a>
          ) : (
            <a class="resource-link" href={talk.href} target="_blank" rel="noreferrer">{talk.venue} — {talk.year}</a>
          )}
          <span class="action-note">{talk.title}</span>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
