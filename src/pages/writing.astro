---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { publications, presentations, secondaryWork, substackPosts } from '../data/site';
import { withBase } from '../utils/paths';
---

<BaseLayout
  title="Writing"
  description="Published writing and public scholarship by Reese Hollister — historical essays, peer-reviewed articles, and public-facing history writing."
  image="/assets/fieldwork/og/og-writing.jpg"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://reesehollister.com' },
      { '@type': 'ListItem', position: 2, name: 'Writing', item: 'https://reesehollister.com/writing' }
    ]
  })} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Writing by Reese W. Hollister',
    description: 'Published historical essays, peer-reviewed articles, conference presentations, and public-facing scholarship.',
    url: 'https://reesehollister.com/writing',
    author: { '@type': 'Person', name: 'Reese W. Hollister', url: 'https://reesehollister.com' },
    hasPart: publications.map(pub => ({
      '@type': 'ScholarlyArticle',
      name: pub.title,
      isPartOf: { '@type': 'Periodical', name: pub.venue },
      datePublished: pub.year,
      url: pub.href,
      author: { '@type': 'Person', name: 'Reese W. Hollister' }
    }))
  })} slot="head" />
  <section class="page-hero site-shell">
    <p class="section-kicker">Writing</p>
    <h1>Writing</h1>
    <p class="page-lead">
      Published work spanning historical method, colonial institutions, postcolonial Africa, and public-facing scholarship.
    </p>
    <p>
      My writing moves between academic venues and public formats. Peer-reviewed work tends toward close argumentation and archival
      grounding. Public writing — including the Historical Method Man channel — aims to make historical thinking legible to an
      audience that did not choose to study it.
    </p>
  </section>

  <section class="site-shell">
    <SectionHeading
      eyebrow="Publications"
      title="Peer-reviewed and published work"
      intro="Articles published in academic history journals. Full archive on Academia.edu."
    />
    <ul class="action-list action-list--stacked">
      {publications.map((pub) => (
        <li>
          <a class="resource-link" href={pub.href} target="_blank" rel="noreferrer">{pub.venue}</a>
          <span class="action-note">{pub.title} ({pub.year})</span>
        </li>
      ))}
    </ul>
  </section>

  <section class="site-shell">
    <SectionHeading
      eyebrow="Presentations"
      title="Conference talks & presentations"
      intro="Talks delivered at academic conferences and graduate research events."
    />
    <ul class="action-list action-list--stacked">
      {presentations.map((talk) => (
        <li>
          {talk.internal ? (
            <a class="resource-link" href={withBase(talk.href)}>{talk.venue}</a>
          ) : (
            <a class="resource-link" href={talk.href} target="_blank" rel="noreferrer">{talk.venue}</a>
          )}
          <span class="action-note">{talk.title} ({talk.year})</span>
        </li>
      ))}
    </ul>
  </section>

  <section class="site-shell">
    <SectionHeading
      eyebrow="Public Scholarship"
      title="Public-facing writing and media"
      intro="Writing and video work designed to reach audiences beyond the seminar room."
    />
    <div class="proof-grid">
      {secondaryWork.map((item) => (
        <article class="proof-card">
          <p class="section-kicker">{item.category}</p>
          <h3>{item.title}</h3>
          <p>{item.summary}</p>
          <a class="resource-link" href={item.href} target="_blank" rel="noreferrer">{item.cta}</a>
        </article>
      ))}
    </div>
  </section>

  <section class="site-shell">
    <SectionHeading
      eyebrow="Newsletter"
      title="Fieldwork & scholarship dispatches"
      intro="Public writing from the field, the classroom, and the research desk — on Substack since 2023."
    />
    <ul class="action-list action-list--stacked">
      {substackPosts.map((post) => (
        <li>
          <a class="resource-link" href={post.href} target="_blank" rel="noreferrer">
            {post.title} — {post.year}
          </a>
          <span class="action-note">{post.subtitle}</span>
        </li>
      ))}
      <li>
        <a class="resource-link" href="https://reesewhollister.substack.com" target="_blank" rel="noreferrer">
          Full archive on Substack
        </a>
        <span class="action-note">All dispatches — Morocco, Oman, teaching, research, and public scholarship writing since 2023.</span>
      </li>
    </ul>
  </section>

  <section class="site-shell">
    <SectionHeading
      eyebrow="Archive"
      title="Full publication record"
      intro="The full trail of published and presented work."
    />
    <ul class="action-list action-list--stacked">
      <li>
        <a class="resource-link" href="https://ncsu.academia.edu/ReeseHollister" target="_blank" rel="noreferrer">
          Academia.edu profile
        </a>
        <span class="action-note">Research profile with all articles, conference presentations, and public-facing work.</span>
      </li>
      <li>
        <a class="resource-link" href="https://www.youtube.com/@HistoricalMethodMan/featured" target="_blank" rel="noreferrer">
          Historical Method Man — YouTube
        </a>
        <span class="action-note">Public scholarship channel with 1,700+ subscribers and 218,000+ views on historical method, research, and language learning.</span>
      </li>
    </ul>
  </section>
</BaseLayout>
